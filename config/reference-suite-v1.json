{
  "$schema": "./bench-run-config.schema.json",
  "schemaVersion": 1,
  "name": "reference-suite-v1",
  "description": "Canonical 26-task reference suite v1, reusing the built-in deterministic corpus by task ID.",
  "tasks": [
    "az-cli/assign-managed-identity",
    "az-cli/create-resource-group",
    "az-cli/keyvault-secret-set",
    "az-cli/query-by-tag",
    "az-cli/storage-account-create",
    "docker-homelab/bridge-network",
    "docker-homelab/compose-version-upgrade",
    "docker-homelab/env-from-file",
    "docker-homelab/named-volume",
    "docker-homelab/redis-healthcheck",
    "docker-homelab/restart-policy",
    "drillbit/backup-policy",
    "drillbit/canary-enable",
    "drillbit/provision-edge",
    "drillbit/rotate-secret",
    "drillbit/scale-replicas",
    "inkwell/add-healthcheck",
    "inkwell/configure-scaling",
    "inkwell/cpu-scaling",
    "inkwell/full-config",
    "inkwell/new-service",
    "inkwell/set-rate-limit",
    "opencode/agents-md-akm-snippet",
    "opencode/provider-akm-feedback",
    "opencode/select-correct-skill",
    "opencode/tool-allowlist"
  ],
  "arms": ["akm"],
  "seeds": 5,
  "budgetTokens": 25000,
  "budgetWallMs": 360000,
  "parallel": 3
}
