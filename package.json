{
  "name": "akm-bench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone benchmark harness for evaluating akm-assisted agent runs.",
  "license": "MPL-2.0",
  "homepage": "https://github.com/itlackey/akm-bench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itlackey/akm-bench.git"
  },
  "bugs": {
    "url": "https://github.com/itlackey/akm-bench/issues"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test ./tests",
    "lint": "bunx biome check src/ tests/",
    "lint:fix": "bunx biome check --write src/ tests/",
    "format": "bunx biome format --write src/ tests/",
    "check": "bun run lint && bun run typecheck && bun test ./tests"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "akm-cli": "^0.7.1",
    "dotenv": "^17.4.2",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.19.17",
    "bun-types": "^1.3.13",
    "typescript": "^5.9.3"
  }
}
