{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "src/**",
      "fixtures/**",
      "config/**",
      "results/**",
      "tests/**",
      "README.md",
      ".gitignore",
      "package.json",
      "tsconfig.json"
    ]
  }
}
